{
  "name": "shard",
  "productName": "Shard",
  "version": "0.1.0",
  "description": "Shard — find any screenshot instantly",
  "author": "Juraij Ahmed",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && electron --js-flags=\"--expose-gc\" .",
    "dev:vite": "cd renderer && vite",
    "build": "cd renderer && vite build",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "image-size": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "trash": "^10.1.1",
    "vectra": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^8.2.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shard.app",
    "productName": "Shard",
    "copyright": "Copyright © 2026",
    "win": {
      "target": "nsis",
      "icon": "renderer/public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shard"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "renderer/public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "renderer/public/fonts",
        "to": "fonts"
      },
      {
        "from": "renderer/public/logo.ico",
        "to": "logo.ico"
      }
    ],
    "directories": {
      "output": "dist-build"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@huggingface/**/*",
      "node_modules/onnxruntime-node/**/*",
      "renderer/public/logo.ico",
      "renderer/public/logo.png"
    ]
  }
}
