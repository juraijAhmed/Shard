{
  "name": "shard",
  "version": "0.1.0",
  "description": "Screenshot Yard — find any screenshot instantly",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite renderer",
    "dev:electron": "wait-on http://localhost:5173 && electron --js-flags=\"--expose-gc\" ."
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "image-size": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0",
    "vectra": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^8.2.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "wait-on": "^7.2.0"
  }
}
